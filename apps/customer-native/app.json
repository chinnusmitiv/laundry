{
  "expo": {
    "name": "ChaseLaundry",
    "slug": "chaselaundry-customer",
    "version": "1.0.0",
    "scheme": "chaselaundrycustomer",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1D2951",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.chaselaundry.customer"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "subarnam",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-mark.png",
          "backgroundColor": "#1D2951"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {}
      ],
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "0d5b1df0-5171-4d01-9796-d5b660deba87"
      }
    }
  }
}
