{
  "expo": {
    "name": "ChaseLaundry Driver",
    "slug": "chaselaundry-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#C7FF33",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.chaselaundry.driver"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bda862bf-7ec8-446d-8a6e-01c3aefe4178"
      }
    },
    "owner": "subarna_m",
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-mark.png",
          "backgroundColor": "#1D2951"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ChaseLaundry Driver uses your location to log clock-in/out and send live tracking updates to customers during pickup and delivery."
        }
      ]
    ]
  }
}
